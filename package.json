{
  "name": "acabalojuez.com",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de predicciones futboleras - entretenimiento sin dinero real",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
